import tkinter as tk
from tkinter import messagebox
import random


class NumberGuessingGame:
    """GUI-based number guessing game using Tkinter"""
    
    def __init__(self, root):
        """Initialize the game window and components"""
        
        self.root = root
        self.root.title("🎮 Number Guessing Game - Coding Samurai")
        self.root.geometry("500x600")
        self.root.configure(bg="#f0f0f0")
        
        # Game variables
        self.secret_number = random.randint(1, 100)
        self.attempts = 0
        self.max_attempts = 10
        self.game_over = False
        
        # Configure window to not be resizable
        self.root.resizable(False, False)
        
        # Create GUI components
        self.create_widgets()
    
    def create_widgets(self):
        """Create all GUI components"""
        
        # Title Frame
        title_frame = tk.Frame(self.root, bg="#2c3e50", height=100)
        title_frame.pack(fill=tk.X)
        
        title_label = tk.Label(
            title_frame,
            text="🎮 NUMBER GUESSING GAME",
            font=("Arial", 20, "bold"),
            bg="#2c3e50",
            fg="white"
        )
        title_label.pack(pady=15)
        
        subtitle_label = tk.Label(
            title_frame,
            text="Guess a number between 1 and 100",
            font=("Arial", 12),
            bg="#2c3e50",
            fg="#ecf0f1"
        )
        subtitle_label.pack()
        
        # Main Content Frame
        content_frame = tk.Frame(self.root, bg="#f0f0f0")
        content_frame.pack(fill=tk.BOTH, expand=True, padx=20, pady=20)
        
        # Instructions
        instructions = tk.Label(
            content_frame,
            text="📝 Instructions:\n"
                 "• Guess a random number\n"
                 "• You have 10 attempts\n"
                 "• Get hints: Too High or Too Low",
            font=("Arial", 10),
            bg="#f0f0f0",
            justify=tk.LEFT
        )
        instructions.pack(pady=10)
        
        # Game Stats Frame
        stats_frame = tk.Frame(content_frame, bg="#ecf0f1", relief=tk.SUNKEN, bd=1)
        stats_frame.pack(fill=tk.X, pady=10)
        
        # Attempts Label
        self.attempts_label = tk.Label(
            stats_frame,
            text=f"Attempts: {self.attempts}/{self.max_attempts}",
            font=("Arial", 11, "bold"),
            bg="#ecf0f1"
        )
        self.attempts_label.pack(pady=8)
        
        # Input Frame
        input_frame = tk.Frame(content_frame, bg="#f0f0f0")
        input_frame.pack(pady=15)
        
        input_label = tk.Label(
            input_frame,
            text="Enter your guess:",
            font=("Arial", 12, "bold"),
            bg="#f0f0f0"
        )
        input_label.pack()
        
        # Entry widget
        self.guess_entry = tk.Entry(
            input_frame,
            font=("Arial", 14, "bold"),
            width=15,
            justify=tk.CENTER
        )
        self.guess_entry.pack(pady=8)
        self.guess_entry.bind("<Return>", lambda e: self.check_guess())
        self.guess_entry.focus()
        
        # Buttons Frame
        buttons_frame = tk.Frame(content_frame, bg="#f0f0f0")
        buttons_frame.pack(pady=10)
        
        # Check Button
        check_button = tk.Button(
            buttons_frame,
            text="✓ Check Guess",
            font=("Arial", 11, "bold"),
            bg="#27ae60",
            fg="white",
            padx=15,
            pady=8,
            command=self.check_guess
        )
        check_button.pack(side=tk.LEFT, padx=5)
        
        # Hint Button
        hint_button = tk.Button(
            buttons_frame,
            text="💡 Get Hint",
            font=("Arial", 11, "bold"),
            bg="#2980b9",
            fg="white",
            padx=15,
            pady=8,
            command=self.get_hint
        )
        hint_button.pack(side=tk.LEFT, padx=5)
        
        # Reset Button
        reset_button = tk.Button(
            buttons_frame,
            text="🔄 New Game",
            font=("Arial", 11, "bold"),
            bg="#f39c12",
            fg="white",
            padx=15,
            pady=8,
            command=self.reset_game
        )
        reset_button.pack(side=tk.LEFT, padx=5)
        
        # Feedback Frame
        feedback_frame = tk.Frame(content_frame, bg="#f0f0f0")
        feedback_frame.pack(fill=tk.BOTH, expand=True, pady=10)
        
        # Feedback Label
        self.feedback_label = tk.Label(
            feedback_frame,
            text="🎯 Start guessing!",
            font=("Arial", 13, "bold"),
            bg="#f0f0f0",
            fg="#2c3e50",
            wraplength=450,
            justify=tk.CENTER
        )
        self.feedback_label.pack(expand=True)
        
        # Guess History Frame
        history_frame = tk.Frame(content_frame, bg="#ecf0f1", relief=tk.SUNKEN, bd=1)
        history_frame.pack(fill=tk.BOTH, expand=True, pady=10)
        
        history_label = tk.Label(
            history_frame,
            text="📋 Guess History:",
            font=("Arial", 10, "bold"),
            bg="#ecf0f1"
        )
        history_label.pack(pady=5)
        
        # Listbox for history
        self.history_listbox = tk.Listbox(
            history_frame,
            font=("Arial", 10),
            height=5,
            bg="white"
        )
        self.history_listbox.pack(fill=tk.BOTH, expand=True, padx=8, pady=8)
        
        self.history = []
    
    def check_guess(self):
        """Check the user's guess"""
        
        if self.game_over:
            messagebox.showinfo("Game Over", "Please start a new game!")
            return
        
        try:
            guess = int(self.guess_entry.get().strip())
            
            # Validate input
            if guess < 1 or guess > 100:
                self.feedback_label.config(
                    text="❌ Please enter a number between 1 and 100!",
                    fg="#e74c3c"
                )
                return
            
            self.attempts += 1
            self.history.append(guess)
            
            # Update history listbox
            self.history_listbox.insert(tk.END, f"Attempt {self.attempts}: {guess}")
            self.history_listbox.see(tk.END)
            
            # Update attempts label
            self.attempts_label.config(
                text=f"Attempts: {self.attempts}/{self.max_attempts}"
            )
            
            # Check if guess is correct
            if guess == self.secret_number:
                self.feedback_label.config(
                    text=f"🎉 Congratulations!\n"
                         f"You found the number {self.secret_number}\n"
                         f"in {self.attempts} attempts!",
                    fg="#27ae60"
                )
                self.game_over = True
                messagebox.showinfo(
                    "🎉 Winner!",
                    f"You found the number {self.secret_number} in {self.attempts} attempts!\n\n"
                    f"Amazing! 🌟"
                )
            
            # Check if guess is too high
            elif guess > self.secret_number:
                remaining = self.max_attempts - self.attempts
                self.feedback_label.config(
                    text=f"📉 Too High!\n"
                         f"Try a smaller number\n"
                         f"({remaining} attempts remaining)",
                    fg="#e67e22"
                )
            
            # Check if guess is too low
            else:
                remaining = self.max_attempts - self.attempts
                self.feedback_label.config(
                    text=f"📈 Too Low!\n"
                         f"Try a larger number\n"
                         f"({remaining} attempts remaining)",
                    fg="#e67e22"
                )
            
            # Check if max attempts reached
            if self.attempts >= self.max_attempts:
                self.feedback_label.config(
                    text=f"💔 Game Over!\n"
                         f"The number was {self.secret_number}\n"
                         f"Better luck next time!",
                    fg="#c0392b"
                )
                self.game_over = True
                messagebox.showwarning(
                    "💔 Game Over",
                    f"You've used all {self.max_attempts} attempts!\n"
                    f"The secret number was: {self.secret_number}"
                )
            
            # Clear input field
            self.guess_entry.delete(0, tk.END)
            self.guess_entry.focus()
        
        except ValueError:
            self.feedback_label.config(
                text="❌ Please enter a valid number!",
                fg="#e74c3c"
            )
    
    def get_hint(self):
        """Provide a hint about the secret number"""
        
        if self.game_over:
            messagebox.showinfo("Game Over", "Please start a new game!")
            return
        
        if not self.history:
            messagebox.showinfo(
                "💡 Hint",
                f"The number is between 1 and 100\n"
                f"Make your first guess!"
            )
        else:
            last_guess = self.history[-1]
            if last_guess < self.secret_number:
                hint = f"The number is higher than {last_guess}"
            else:
                hint = f"The number is lower than {last_guess}"
            
            messagebox.showinfo("💡 Hint", hint)
    
    def reset_game(self):
        """Reset the game for a new round"""
        
        self.secret_number = random.randint(1, 100)
        self.attempts = 0
        self.game_over = False
        self.history = []
        
        # Update GUI
        self.attempts_label.config(text=f"Attempts: 0/{self.max_attempts}")
        self.feedback_label.config(
            text="🎯 Start guessing!",
            fg="#2c3e50"
        )
        self.history_listbox.delete(0, tk.END)
        self.guess_entry.delete(0, tk.END)
        self.guess_entry.focus()
        
        messagebox.showinfo(
            "🔄 New Game",
            "Game has been reset!\nGuess a new number between 1 and 100"
        )


def main():
    """Main application entry point"""
    
    root = tk.Tk()
    game = NumberGuessingGame(root)
    root.mainloop()


if __name__ == "__main__":
    main()