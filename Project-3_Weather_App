import requests
import json
from datetime import datetime

# OpenWeatherMap API endpoint (free tier)
API_URL = "https://api.openweathermap.org/data/2.5/weather"

# Free API key - Get yours from: https://openweathermap.org/api
API_KEY = "YOUR_API_KEY_HERE"  # Replace with your actual API key


def get_weather(city_name, api_key=API_KEY):
    """
    Fetch weather data from OpenWeatherMap API
    
    Args:
        city_name (str): Name of the city
        api_key (str): OpenWeatherMap API key
    
    Returns:
        dict: Weather data or None if error occurs
    """
    
    # Parameters for API request
    params = {
        'q': city_name,
        'appid': api_key,
        'units': 'metric'  # Temperature in Celsius
    }
    
    try:
        print(f"\n🔍 Fetching weather data for {city_name}...")
        
        # Make API request
        response = requests.get(API_URL, params=params)
        
        # Check if request was successful
        if response.status_code == 200:
            weather_data = response.json()
            return weather_data
        
        elif response.status_code == 404:
            print(f"❌ City '{city_name}' not found! Please check spelling.")
            return None
        
        elif response.status_code == 401:
            print("❌ Invalid API key! Get one from https://openweathermap.org/api")
            return None
        
        else:
            print(f"❌ Error {response.status_code}: Unable to fetch weather data")
            return None
    
    except requests.exceptions.ConnectionError:
        print("❌ Connection Error! Please check your internet connection.")
        return None
    
    except requests.exceptions.Timeout:
        print("❌ Request Timeout! API server not responding.")
        return None
    
    except Exception as e:
        print(f"❌ Error: {str(e)}")
        return None


def parse_weather_data(data):
    """
    Parse and format weather data from API response
    
    Args:
        data (dict): Raw weather data from API
    
    Returns:
        dict: Formatted weather information
    """
    
    weather_info = {
        'city': data['name'],
        'country': data['sys']['country'],
        'temperature': data['main']['temp'],
        'feels_like': data['main']['feels_like'],
        'temp_min': data['main']['temp_min'],
        'temp_max': data['main']['temp_max'],
        'humidity': data['main']['humidity'],
        'pressure': data['main']['pressure'],
        'description': data['weather'][0]['description'],
        'wind_speed': data['wind']['speed'],
        'cloudiness': data['clouds']['all'],
        'sunrise': data['sys']['sunrise'],
        'sunset': data['sys']['sunset'],
        'timezone': data['timezone']
    }
    
    return weather_info


def display_weather(weather_info):
    """
    Display weather information in a formatted way
    
    Args:
        weather_info (dict): Parsed weather information
    """
    
    print("\n" + "="*70)
    print(f"        🌍 WEATHER INFO FOR {weather_info['city'].upper()}, {weather_info['country']}")
    print("="*70)
    
    # Current temperature section
    print(f"\n🌡️  CURRENT TEMPERATURE")
    print(f"   Temperature: {weather_info['temperature']}°C")
    print(f"   Feels Like: {weather_info['feels_like']}°C")
    print(f"   Min Temp: {weather_info['temp_min']}°C")
    print(f"   Max Temp: {weather_info['temp_max']}°C")
    
    # Weather description
    print(f"\n☁️  WEATHER CONDITIONS")
    print(f"   Description: {weather_info['description'].capitalize()}")
    print(f"   Cloudiness: {weather_info['cloudiness']}%")
    
    # Atmospheric conditions
    print(f"\n💨 ATMOSPHERIC CONDITIONS")
    print(f"   Wind Speed: {weather_info['wind_speed']} m/s")
    print(f"   Humidity: {weather_info['humidity']}%")
    print(f"   Pressure: {weather_info['pressure']} hPa")
    
    # Sun timing
    sunrise_time = datetime.fromtimestamp(weather_info['sunrise']).strftime("%H:%M:%S")
    sunset_time = datetime.fromtimestamp(weather_info['sunset']).strftime("%H:%M:%S")
    
    print(f"\n🌅 SUN TIMING")
    print(f"   Sunrise: {sunrise_time}")
    print(f"   Sunset: {sunset_time}")
    
    print("\n" + "="*70 + "\n")


def get_multiple_cities():
    """Fetch and display weather for multiple cities"""
    
    print("\n" + "="*70)
    print("           🌐 MULTIPLE CITIES WEATHER CHECK")
    print("="*70)
    
    cities = []
    print("\nEnter city names (type 'done' when finished):")
    
    while True:
        city = input("Enter city name: ").strip()
        
        if city.lower() == 'done':
            if len(cities) == 0:
                print("❌ Please enter at least one city!")
                continue
            break
        
        if city == "":
            print("❌ City name cannot be empty!")
            continue
        
        cities.append(city)
        print(f"✅ Added: {city}")
    
    # Fetch weather for all cities
    for city in cities:
        data = get_weather(city)
        
        if data:
            weather_info = parse_weather_data(data)
            display_weather(weather_info)
        else:
            print(f"⚠️  Skipping {city}...\n")


def main():
    """Main application function"""
    
    print("\n" + "="*70)
    print("               🌤️  WEATHER APP - CODING SAMURAI")
    print("="*70)
    print("\n⚠️  NOTE: Replace 'YOUR_API_KEY_HERE' with actual API key!")
    print("   Get free API key from: https://openweathermap.org/api")
    print("="*70)
    
    while True:
        print("\n" + "-"*70)
        print("\nMENU:")
        print("1. Check weather for a single city")
        print("2. Check weather for multiple cities")
        print("3. Exit")
        print("-"*70)
        
        choice = input("\nEnter your choice (1/2/3): ").strip()
        
        if choice == '1':
            city_name = input("\nEnter city name: ").strip()
            
            if city_name == "":
                print("❌ City name cannot be empty!")
                continue
            
            data = get_weather(city_name)
            
            if data:
                weather_info = parse_weather_data(data)
                display_weather(weather_info)
        
        elif choice == '2':
            get_multiple_cities()
        
        elif choice == '3':
            print("\n👋 Thank you for using Weather App! Stay safe! 🌈")
            break
        
        else:
            print("❌ Invalid choice! Please enter 1, 2, or 3.")


# Run the application
if __name__ == "__main__":
    main()